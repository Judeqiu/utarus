# Demo agent — copy to .env and fill in secrets.
# Host owns dotenv (UTARUS_LOADED_BY_HOST is set in src/index.ts).

# ── Identity ──────────────────────────────────────────────
UTARUS_AGENT_NAME=Demo
UTARUS_AGENT_PURPOSE=Sample Utarus agent for Stripe paywall walkthrough (free → Pro).
UTARUS_DATA_ROOT=./data

# ── LLM (required) ────────────────────────────────────────
# DeepSeek (default)
DEEPSEEK_API_KEY=sk-...
# Or: UTARUS_LLM_PROVIDER=kimi + KIMI_API_KEY=...

# ── WebUI (required for Billing page / Checkout) ──────────
WEBAPP_PORT=3010
SESSION_SECRET=change-me-demo-session-secret
# SPA admin login (username/password on the same form as normal users)
WEBAPP_ADMIN_CREDENTIALS={"admin":"demo-admin-pass"}
# On boot, seeds a normal user: slug=demo password=demo1234
# DEMO_RESET_USER=1

# Public origin used for Checkout success/cancel + bot magic links.
# Local: use http://localhost:3010  (Stripe CLI for webhooks — see README)
UTARUS_PUBLIC_BASE_URL=http://localhost:3010
UTARUS_REPORTS_URL=http://localhost:3010

# ── Billing / Stripe ──────────────────────────────────────
# Set exactly "true" to enable paywall (createFramework fails fast if incomplete)
UTARUS_BILLING_ENABLED=true
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
# Must match a Price in your Stripe test mode Dashboard
STRIPE_PRICE_ID=price_...

# ── Optional channels ─────────────────────────────────────
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_ADMIN_IDS=
# SLACK_BOT_TOKEN=
# SLACK_APP_TOKEN=
# SLACK_SIGNING_SECRET=
# SLACK_ADMIN_IDS=

# DEMO_CLI=1
