# Primary LLM — DeepSeek by default. Set DEEPSEEK_API_KEY unless you opt into Kimi or generic below.
DEEPSEEK_API_KEY=

# Optional: switch to Kimi K3 (OpenAI-compatible endpoint) by setting UTARUS_LLM_PROVIDER=kimi.
# When set, DEEPSEEK_API_KEY is no longer required; KIMI_API_KEY is.
# UTARUS_LLM_PROVIDER=kimi
# KIMI_API_KEY=
# UTARUS_LLM_MODEL=k3  # k3 (default) | kimi-for-coding | kimi-for-coding-highspeed
# UTARUS_LLM_BASE_URL=https://api.kimi.com/coding/v1  # default shown

# Optional: any other OpenAI-compatible endpoint (OpenRouter, vLLM, Ollama, etc.).
# All three values are required; there are no defaults under `generic`.
# UTARUS_LLM_PROVIDER=generic
# UTARUS_LLM_MODEL=llama-3.3-70b-instruct
# UTARUS_LLM_BASE_URL=http://localhost:11434/v1
# UTARUS_LLM_API_KEY=sk-...                       # default api-key env var
# UTARUS_LLM_API_KEY_ENV=MY_CUSTOM_KEY_ENV_VAR    # optional override of the env-var name

# Optional: override the resolved model's image-input (vision) capability, which
# gates WebUI chat photo attachments. Defaults come from the provider's declared
# capabilities (deepseek=false, kimi=true, generic=false); per-model deltas and
# this override are applied on top. See README → Capability model.
# (Legacy single-provider mode only — in multi-profile routing set imageInput per profile.)
# UTARUS_LLM_IMAGE_INPUT=true

# ── Multi-LLM task routing (optional) ───────────────────────────────────
# When UTARUS_LLM_PROFILES is set, UTARUS_LLM_ROUTING is REQUIRED.
# Legacy UTARUS_LLM_PROVIDER is ignored for agent resolution in routing mode.
# Example: DeepSeek for daily chat, Kimi for image turns.
# DEEPSEEK_API_KEY=…
# KIMI_API_KEY=…
# UTARUS_LLM_PROFILES={"daily":{"provider":"deepseek"},"vision":{"provider":"kimi"}}
# UTARUS_LLM_ROUTING={"default":"daily","has_images":"vision","utility":"daily"}
# Optional heavy heuristics (only if routing.heavy is set):
# UTARUS_LLM_ROUTE_HEAVY_MIN_CHARS=4000
# UTARUS_LLM_ROUTE_HEAVY_KEYWORDS=deep dive,comprehensive analysis
# Optional unified-cap weights (every declared profile must be listed if set):
# UTARUS_LLM_CAP_WEIGHTS={"daily":1,"vision":2}
# See docs/multi-llm-routing-design.md.

# Optional: WebUI/Slack agent run watchdog (ms). Default 600000 (10 min).
# Set to 0 to disable (long multi-tool listing hunts won't abort).
# UTARUS_AGENT_RUN_TIMEOUT_MS=0

# Telegram bot token from @BotFather — optional, omit to disable Telegram
TELEGRAM_BOT_TOKEN=

# Comma-separated Telegram user IDs with admin access (bootstrap list).
# More admins can be granted at runtime via /admincode.
TELEGRAM_ADMIN_IDS=

# Slack configuration — optional, omit to disable Slack
# See https://api.slack.com/apps to create a Slack app
# Enable Socket Mode and add Bot Token Scopes: chat:write, commands, im:write
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
SLACK_SIGNING_SECRET=

# Comma-separated Slack user IDs with admin access (bootstrap list).
SLACK_ADMIN_IDS=

# Per-user YAML state files live here. Defaults to ./data
UTARUS_DATA_ROOT=./data

# Required: agent name shown in CLI prompt and system prompt
UTARUS_AGENT_NAME=Utarus

# Required: short description of what this agent does, injected into system prompt
UTARUS_AGENT_PURPOSE=You are a generic agent built on the Utarus framework. Help the user with their task, call tools as needed, and stay within the scope defined by the loaded skills.

# Optional: WebUI interactive maps (Google Maps Embed). Off unless flag is exactly true
# and a non-empty browser Embed API key is set. Restrict the key to HTTP referrers
# (WebUI origin) and Maps Embed API only. See docs/webui-chat-maps-design.md.
# UTARUS_MAPS_ENABLED=true
# GOOGLE_MAPS_EMBED_API_KEY=
