# DeepSeek API (primary LLM) — required
DEEPSEEK_API_KEY=

# Telegram bot token from @BotFather — optional, omit to run CLI-only
TELEGRAM_BOT_TOKEN=

# Comma-separated Telegram user IDs with admin access (bootstrap list).
# More admins can be granted at runtime via /admincode.
TELEGRAM_ADMIN_IDS=

# Per-user YAML state files live here. Defaults to ./data
UTARUS_DATA_ROOT=./data

# Required: agent name shown in CLI prompt and system prompt
UTARUS_AGENT_NAME=Utarus

# Required: short description of what this agent does, injected into system prompt
UTARUS_AGENT_PURPOSE=You are a generic agent built on the Utarus framework. Help the user with their task, call tools as needed, and stay within the scope defined by the loaded skills.
